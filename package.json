{
  "name": "cafepos-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "service"
  ],
  "scripts": {
    "dev": "zellij --layout scripts/dev-zellij.kdl",
    "dev:client": "npm run dev -w client",
    "dev:service": "npm run dev -w service",
    "dev:zellij": "zellij --layout scripts/dev-zellij.kdl",
    "build": "npm run -ws --if-present build",
    "typecheck": "npm run -ws --if-present typecheck",
    "lint": "npm run -ws --if-present lint",
    "lint:fix": "npm run -ws --if-present lint:fix",
    "clean": "npm run -ws --if-present clean",
    "start": "npm run start -w service",
    "start:client": "npm run start -w client",
    "preview": "npm run preview -w client"
  },
  "devDependencies": {}
}
